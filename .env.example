# -----------------------------------------------------------------------------
# Database (Supabase Postgres)
# -----------------------------------------------------------------------------
# Runtime queries go through the Supabase "Transaction pooler" (port 6543).
# That's the pooler designed for serverless platforms like Vercel — it lets
# many lambdas share a small backend connection budget. The session pooler
# (port 5432) holds one Postgres connection per client and exhausts under
# serverless load, which manifests as random 5-minute auth outages.
#
# `pgbouncer=true` tells Prisma to skip prepared statements (PgBouncer
# transaction mode doesn't support them), and `connection_limit=1` keeps each
# lambda from grabbing more than one pooled connection.
DATABASE_URL="postgresql://postgres.<project>:<password>@aws-1-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Direct connection (port 5432) used ONLY by `prisma migrate` — migrations
# need a real session and can't run through PgBouncer transaction mode.
DIRECT_URL="postgresql://postgres.<project>:<password>@aws-1-us-east-1.pooler.supabase.com:5432/postgres"

# -----------------------------------------------------------------------------
# NextAuth
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="generate-a-random-32-char-string"

# Locally this is http://localhost:3000
# In Vercel: set to your production URL, e.g. https://portal.yourdomain.com
# For Preview deployments Vercel auto-sets NEXTAUTH_URL via VERCEL_URL — you
# can leave it blank there and rely on the fallback in next-auth's logic, OR
# set NEXTAUTH_URL_INTERNAL per environment.
NEXTAUTH_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Google Drive — Workload Identity Federation (keyless auth, required on Vercel)
# iam.disableServiceAccountKeyCreation org policy blocks JSON key downloads;
# WIF is the correct alternative. VERCEL_OIDC_TOKEN is injected automatically.
# -----------------------------------------------------------------------------
# GCP_PROJECT_NUMBER=          # GCP Console → IAM → Settings → Project number
# GCP_WORKLOAD_IDENTITY_POOL_ID=     # IAM → Workload Identity Federation → pool ID
# GCP_WORKLOAD_IDENTITY_PROVIDER_ID= # same pool → Providers → provider ID
# GCP_SERVICE_ACCOUNT_EMAIL=         # portal-storage@<project>.iam.gserviceaccount.com
# GOOGLE_DRIVE_SHARED_DRIVE_ID=
# GOOGLE_DRIVE_ROOT_FOLDER_ID=
# GOOGLE_ESIGN_WEBHOOK_SECRET=       # Reserved — for the future eSignature webhook
# GOOGLE_DRIVE_HANDBOOK_FILE_ID=     # Drive file ID of the master Employee Handbook
# NEXT_PUBLIC_APP_URL=                # Base URL used in transactional emails, e.g. https://portal.planetpooch.com

# -----------------------------------------------------------------------------
# Email (Resend) — used for the new-hire welcome email
# -----------------------------------------------------------------------------
# Get an API key at https://resend.com. The "from" address must be on a domain
# you've verified there (DKIM + SPF). NEXT_PUBLIC_APP_URL above controls the
# /login link in the email body; if it's blank the code falls back to NEXTAUTH_URL.
# RESEND_API_KEY=
# RESEND_FROM_EMAIL="Planet Pooch <noreply@planetpooch.com>"

# -----------------------------------------------------------------------------
# Meta Ads — server-to-server insights sync
# -----------------------------------------------------------------------------
# We use a System User access token owned by the Business Manager that owns
# the ad account. No per-user OAuth, no Meta App Review needed (it's
# first-party data). Setup:
#   1. Business Settings → System Users → Add (give it "Admin" or
#      "Employee" role, doesn't matter which for read-only access).
#   2. Business Settings → Accounts → Apps → confirm your Meta app is
#      added to the Business. If not, "Add → Connect a Business app ID".
#   3. Business Settings → Users → System Users → [your system user] →
#      Add Assets → Apps → select the app and grant "Develop app" access.
#      WITHOUT THIS the Generate Token dialog will show "No permissions
#      available — Assign an app role to the system user or select
#      another app to continue".
#   4. Add Assets → Ad Accounts → assign the ad account with at least
#      "View performance" permission.
#   5. Generate Token → pick the same app from step 3 → scopes: `ads_read`.
#      Set "Token expiration" to "Never" — that's the long-lived flow.
# META_ACCESS_TOKEN=
# META_AD_ACCOUNT_ID=act_1234567890   # find in Ads Manager URL
# META_API_VERSION=v21.0              # optional; pin to a known version

# -----------------------------------------------------------------------------
# Vercel Cron — protects /api/.../cron from public GET. Generate with:
#   openssl rand -base64 32
# Vercel auto-attaches `Authorization: Bearer ${CRON_SECRET}` to scheduled
# requests; we reject anything without a matching header.
# -----------------------------------------------------------------------------
# CRON_SECRET=
