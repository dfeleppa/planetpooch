# -----------------------------------------------------------------------------
# Database (Supabase Postgres)
# -----------------------------------------------------------------------------
# Use the Supabase "Session pooler" connection string (port 5432).
# In Vercel, add this as DATABASE_URL for Production + Preview + Development.
DATABASE_URL="postgresql://postgres.<project>:<password>@aws-1-us-east-1.pooler.supabase.com:5432/postgres"

# -----------------------------------------------------------------------------
# NextAuth
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="generate-a-random-32-char-string"

# Locally this is http://localhost:3000
# In Vercel: set to your production URL, e.g. https://portal.yourdomain.com
# For Preview deployments Vercel auto-sets NEXTAUTH_URL via VERCEL_URL — you
# can leave it blank there and rely on the fallback in next-auth's logic, OR
# set NEXTAUTH_URL_INTERNAL per environment.
NEXTAUTH_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Google Workspace (Phase 3+) — not needed until Drive integration is wired up
# -----------------------------------------------------------------------------
# GOOGLE_SERVICE_ACCOUNT_EMAIL=
# GOOGLE_SERVICE_ACCOUNT_KEY_BASE64=
# GOOGLE_DRIVE_SHARED_DRIVE_ID=
# GOOGLE_DRIVE_ROOT_FOLDER_ID=
# GOOGLE_ESIGN_WEBHOOK_SECRET=
# NEXT_PUBLIC_APP_URL=
