generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  SUPER_ADMIN
  MANAGER
  EMPLOYEE
  MARKETING
  ADMIN // legacy — existing rows only, use SUPER_ADMIN for new admins
}

enum Company {
  GROOMING
  RESORT
  CORPORATE
}

enum AuditAction {
  COMPLETED
  UNCOMPLETED
}

enum RecurrenceInterval {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
  CUSTOM
}

enum MaintenanceTaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  OVERDUE
  SKIPPED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ============================================================
// Onboarding enums (Phase 2+)
// ============================================================

enum OnboardingTaskType {
  ESIGN_REQUEST       // Employee signs doc via Google eSignature (admin triggers)
  EMPLOYEE_CONFIRM    // Employee self-reports done (e.g., "Bring ID to meeting")
  ADMIN_FILE_UPLOAD   // Admin uploads a file to employee's Drive folder
  ADMIN_TASK          // Admin-only self-reported checkbox
}

enum EsignRequestStatus {
  SENT
  SIGNED
  CANCELLED
}

enum DayOfWeek {
  SUNDAY
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}

enum EmployeeDocumentCategory {
  I9
  ID_CARD
  SS_CARD
  OTHER
}

enum ServiceLine {
  GROOMING
  DAYCARE
  BOARDING
  TRAINING
  MULTIPLE
}

enum IdeaStatus {
  DRAFT
  IN_PRODUCTION
  SHIPPED
  ARCHIVED
}

enum Platform {
  REELS
  TIKTOK
  YT_SHORTS
  META_FEED
  FB_FEED
  MULTI
}

enum ScriptStatus {
  DRAFT
  APPROVED
  FILMED
  POSTED
  ARCHIVED
}

enum HookStatus {
  DRAFT
  APPROVED
  REJECTED
  WINNER
}

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  passwordHash       String
  name               String
  firstName          String
  lastName           String
  role               Role      @default(EMPLOYEE)
  company            Company   @default(CORPORATE)
  mustChangePassword Boolean   @default(false)
  hireDate           DateTime?
  jobTitle           String?
  department         String?
  phone              String?
  managerId          String?
  driveFolderId      String?   // Google Drive folder for this employee's signed docs

  // Termination — null = active employee. When set, blocks login and excludes
  // the user from active employee listings. Reactivation clears all three.
  terminatedAt      DateTime?
  terminationReason String?
  terminatedById    String?

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  manager  User?  @relation("UserManager", fields: [managerId], references: [id])
  reports  User[] @relation("UserManager")

  terminatedBy        User?  @relation("UserTerminator", fields: [terminatedById], references: [id], onDelete: SetNull)
  employeesTerminated User[] @relation("UserTerminator")

  completions LessonCompletion[]
  auditLogs   CompletionAuditLog[]
  notes       EmployeeNote[]

  // Maintenance relations
  maintenanceSchedulesCreated MaintenanceSchedule[] @relation("MaintenanceCreator")
  maintenanceTasksAssigned    MaintenanceTask[]     @relation("MaintenanceAssignee")
  maintenanceTasksCompleted   MaintenanceTask[]     @relation("MaintenanceCompleter")
  inventoryAdjustments        InventoryAdjustment[] @relation("InventoryAdjuster")

  // Task Manager relations
  projectsOwned    Project[]        @relation("ProjectOwner")
  projectMembers   ProjectMember[]
  tasksCreated     Task[]           @relation("TaskCreator")
  taskAssignments  TaskAssignee[]
  taskComments     TaskComment[]

  // Onboarding relations
  onboardingTemplatesCreated OnboardingTemplate[] @relation("TemplateCreator")

  // eSignature relations
  esignRequests          EsignRequest[] @relation("EsignSigner")
  esignRequestsRequested EsignRequest[] @relation("EsignRequester")

  // Availability (recurring weekly schedule)
  availability EmployeeAvailability[]

  // Document uploads
  employeeDocuments EmployeeDocument[] @relation("DocumentSubject")
  documentsUploaded EmployeeDocument[] @relation("DocumentUploader")

  // Org chart relation
  orgPosition OrgPosition? @relation("UserPosition")

  // Module assignments — modules explicitly granted to this user beyond
  // whatever their job title would already grant.
  moduleAssignments ModuleUserAssignment[]

  // Marketing relations
  voiceProfilesCreated BrandVoiceProfile[] @relation("VoiceProfileCreator")
  marketingIdeasCreated MarketingIdea[]    @relation("MarketingIdeaCreator")
  scriptsCreated        Script[]           @relation("ScriptCreator")

  @@index([terminatedAt])
}

model OrgPosition {
  id               String   @id @default(cuid())
  title            String
  company          Company? // null = cross-company (CEO, Director of Strategy)
  parentPositionId String?
  assignedUserId   String?  @unique
  order            Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  parent       OrgPosition?  @relation("PositionHierarchy", fields: [parentPositionId], references: [id], onDelete: SetNull)
  children     OrgPosition[] @relation("PositionHierarchy")
  assignedUser User?         @relation("UserPosition", fields: [assignedUserId], references: [id], onDelete: SetNull)

  @@index([parentPositionId])
  @@index([company])
}

model Module {
  id          String   @id @default(cuid())
  title       String
  description String   @default("")
  order       Int
  icon        String?
  notesEnabled Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subsections     Subsection[]
  prerequisites   ModulePrerequisite[]      @relation("DependentModule")
  dependents      ModulePrerequisite[]      @relation("PrerequisiteModule")
  jobTitleAssignments ModuleJobTitleAssignment[]
  userAssignments     ModuleUserAssignment[]
}

/// Grants a module to every active user whose `User.jobTitle` matches this
/// row's `jobTitle` (case-sensitive, matching the value stored on User).
/// A module with no rows here AND no rows in ModuleUserAssignment is
/// considered "open" — visible to every employee. The migration that
/// introduces this table seeds one row per (module, distinct existing
/// jobTitle) so existing modules keep their current visibility.
model ModuleJobTitleAssignment {
  id        String   @id @default(cuid())
  moduleId  String
  jobTitle  String
  createdAt DateTime @default(now())

  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([moduleId, jobTitle])
  @@index([jobTitle])
}

/// Individually grants a module to a specific user, on top of any
/// job-title-based access. Removing a user's job title doesn't revoke
/// these.
model ModuleUserAssignment {
  id         String   @id @default(cuid())
  moduleId   String
  userId     String
  assignedAt DateTime @default(now())

  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([moduleId, userId])
  @@index([userId])
}

model Subsection {
  id          String   @id @default(cuid())
  title       String
  description String   @default("")
  order       Int
  moduleId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  module  Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@index([moduleId])
}

model Lesson {
  id               String   @id @default(cuid())
  title            String
  content          Json     @default("{}")
  order            Int
  subsectionId     String
  estimatedMinutes Int?
  searchText       String   @default("")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  subsection  Subsection           @relation(fields: [subsectionId], references: [id], onDelete: Cascade)
  completions LessonCompletion[]
  auditLogs   CompletionAuditLog[]
  notes       EmployeeNote[]

  @@index([subsectionId])
}

model LessonCompletion {
  id          String   @id @default(cuid())
  userId      String
  lessonId    String
  completedAt DateTime @default(now())
  isCompleted Boolean  @default(true)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
}

model CompletionAuditLog {
  id                  String      @id @default(cuid())
  userId              String
  lessonId            String
  action              AuditAction
  timestamp           DateTime    @default(now())
  previousCompletedAt DateTime?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([lessonId])
  @@index([timestamp])
}

model ModulePrerequisite {
  id                   String @id @default(cuid())
  moduleId             String
  prerequisiteModuleId String

  module       Module @relation("DependentModule", fields: [moduleId], references: [id], onDelete: Cascade)
  prerequisite Module @relation("PrerequisiteModule", fields: [prerequisiteModuleId], references: [id], onDelete: Cascade)

  @@unique([moduleId, prerequisiteModuleId])
}

model EmployeeNote {
  id        String   @id @default(cuid())
  userId    String
  lessonId  String
  content   String   @default("")
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

// ============================================================
// Maintenance Models
// ============================================================

model MaintenanceSchedule {
  id                 String             @id @default(cuid())
  title              String
  description        String             @default("")
  recurrenceInterval RecurrenceInterval
  customIntervalDays Int?
  startDate          DateTime
  nextDueDate        DateTime
  isActive           Boolean            @default(true)
  createdById        String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  createdBy    User?                           @relation("MaintenanceCreator", fields: [createdById], references: [id], onDelete: SetNull)
  tasks        MaintenanceTask[]
  requirements MaintenanceInventoryRequirement[]

  company Company @default(GROOMING)

  @@index([nextDueDate])
  @@index([createdById])
  @@index([company])
}

model MaintenanceTask {
  id            String                @id @default(cuid())
  scheduleId    String?
  title         String
  description   String                @default("")
  status        MaintenanceTaskStatus @default(PENDING)
  dueDate       DateTime
  completedAt   DateTime?
  assignedToId  String?
  completedById String?
  notes         String                @default("")
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  schedule    MaintenanceSchedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  assignedTo  User?                @relation("MaintenanceAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  completedBy User?                @relation("MaintenanceCompleter", fields: [completedById], references: [id], onDelete: SetNull)
  usages      InventoryUsage[]

  company Company @default(GROOMING)

  @@index([scheduleId])
  @@index([assignedToId])
  @@index([dueDate])
  @@index([status])
  @@index([company])
}

model InventoryCategory {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("bg-gray-100 text-gray-800")
  company   Company  @default(GROOMING)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items InventoryItem[]

  @@unique([name, company])
  @@index([company])
}

model InventoryItem {
  id               String   @id @default(cuid())
  name             String
  description      String   @default("")
  categoryId       String
  unit             String   @default("units")
  currentQuantity  Int      @default(0)
  minimumThreshold Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  category     InventoryCategory           @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  requirements MaintenanceInventoryRequirement[]
  usages       InventoryUsage[]
  adjustments  InventoryAdjustment[]

  company Company @default(GROOMING)

  @@index([categoryId])
  @@index([company])
}

model MaintenanceInventoryRequirement {
  id               String @id @default(cuid())
  scheduleId       String
  inventoryItemId  String
  quantityRequired Int

  schedule      MaintenanceSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem       @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@unique([scheduleId, inventoryItemId])
  @@index([inventoryItemId])
}

model InventoryUsage {
  id                String   @id @default(cuid())
  maintenanceTaskId String
  inventoryItemId   String
  quantityUsed      Int
  recordedAt        DateTime @default(now())

  maintenanceTask MaintenanceTask @relation(fields: [maintenanceTaskId], references: [id], onDelete: Cascade)
  inventoryItem   InventoryItem   @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@index([maintenanceTaskId])
  @@index([inventoryItemId])
}

model InventoryAdjustment {
  id              String   @id @default(cuid())
  inventoryItemId String
  quantityChange  Int
  reason          String   @default("")
  adjustedById    String?
  createdAt       DateTime @default(now())

  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  adjustedBy    User?         @relation("InventoryAdjuster", fields: [adjustedById], references: [id], onDelete: SetNull)

  @@index([inventoryItemId])
}

// ============================================================
// Task Manager Models
// ============================================================

model Project {
  id          String   @id @default(cuid())
  name        String
  description String   @default("")
  ownerId     String?
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner       User?           @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  members     ProjectMember[]
  subProjects SubProject[]
  tasks       Task[]

  @@index([ownerId])
}

model SubProject {
  id          String   @id @default(cuid())
  name        String
  description String   @default("")
  projectId   String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@index([projectId])
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  role      String   @default("MEMBER")
  joinedAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
}

model Task {
  id           String       @id @default(cuid())
  title        String
  description  String       @default("")
  status       TaskStatus   @default(TODO)
  priority     TaskPriority @default(MEDIUM)
  order        Int          @default(0)
  dueDate      DateTime?
  projectId    String
  subProjectId String?
  parentTaskId String?
  createdById  String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  project    Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  subProject SubProject?  @relation(fields: [subProjectId], references: [id], onDelete: SetNull)
  parentTask Task?        @relation("TaskSubtasks", fields: [parentTaskId], references: [id], onDelete: Cascade)
  subtasks   Task[]       @relation("TaskSubtasks")
  createdBy  User?        @relation("TaskCreator", fields: [createdById], references: [id], onDelete: SetNull)
  assignees  TaskAssignee[]
  comments   TaskComment[]

  @@index([projectId])
  @@index([subProjectId])
  @@index([parentTaskId])
  @@index([status])
  @@index([dueDate])
}

model TaskAssignee {
  id         String   @id @default(cuid())
  taskId     String
  userId     String
  assignedAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([userId])
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

// ============================================================
// Onboarding Models (Phase 2: templates only — no assignment yet)
// ============================================================

model OnboardingTemplate {
  id          String   @id @default(cuid())
  name        String
  description String   @default("")
  isActive    Boolean  @default(true)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User?                    @relation("TemplateCreator", fields: [createdById], references: [id], onDelete: SetNull)
  tasks     OnboardingTemplateTask[]

  @@index([createdById])
}

model OnboardingTemplateTask {
  id          String             @id @default(cuid())
  templateId  String
  type        OnboardingTaskType
  title       String
  description String             @default("")
  required    Boolean            @default(true)
  order       Int
  // Type-specific fields (nullable because only some types use each)
  handbookFileName String?        // For ESIGN_REQUEST — label shown in admin UI
  externalUrl      String?        // For ADMIN_TASK — optional link (e.g., ADP)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  template OnboardingTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
}

// ============================================================
// eSignature Models
// ============================================================

/// Library of master documents (in the Google Shared Drive) that can be sent
/// to employees for signature. Admins register them once with their Drive file
/// ID; per-employee requests copy the file into the employee's Drive folder.
model SignableDocument {
  id          String   @id @default(cuid())
  name        String   // e.g. "Employee Handbook"
  description String   @default("")
  driveFileId String   // Source file in the shared drive
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  esignRequests EsignRequest[]

  @@index([isActive])
}

/// One row per (employee, document) signing request. Status flips from SENT
/// to SIGNED when the admin confirms the employee has signed (manual today;
/// will be replaced by a Google eSignature webhook later). The actual signed
/// file lives in the employee's Drive folder — `signedFileDriveId` points at
/// it so the UI can render a "View signed copy" link.
model EsignRequest {
  id                 String             @id @default(cuid())
  userId             String             // The employee who needs to sign
  signableDocumentId String
  requestedById      String?            // Admin who initiated the request
  signedFileDriveId  String?            // Copy in the employee's Drive folder
  status             EsignRequestStatus @default(SENT)
  sentAt             DateTime           @default(now())
  signedAt           DateTime?
  cancelledAt        DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user             User             @relation("EsignSigner", fields: [userId], references: [id], onDelete: Cascade)
  signableDocument SignableDocument @relation(fields: [signableDocumentId], references: [id], onDelete: Restrict)
  requestedBy      User?            @relation("EsignRequester", fields: [requestedById], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([signableDocumentId])
  @@index([status])
}

/// One file uploaded to the employee's Drive folder. Categories like I-9 /
/// ID Card / SS Card are common enough to enumerate; everything else lives
/// under OTHER and uses `customName` as the human label.
model EmployeeDocument {
  id           String                   @id @default(cuid())
  userId       String
  category     EmployeeDocumentCategory
  customName   String?                  // Required when category=OTHER, null otherwise
  fileName     String                   // Original filename from upload
  driveFileId  String                   // Underlying file in Drive (employee's folder)
  mimeType     String
  fileSize     Int                      // bytes
  uploadedById String?
  uploadedAt   DateTime                 @default(now())
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt

  user       User  @relation("DocumentSubject", fields: [userId], references: [id], onDelete: Cascade)
  uploadedBy User? @relation("DocumentUploader", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([category])
}

// ============================================================
// Marketing Models
// ============================================================

/// Versioned brand voice profile. Saving the editor inserts a new row rather
/// than updating the existing one, so every generator call can stamp the exact
/// version it referenced. The "current" profile is the row with the highest
/// version. Older versions are kept for audit + correlating quality changes
/// to voice changes.
model BrandVoiceProfile {
  id              String   @id @default(cuid())
  version         Int      @unique
  tone            String   @default("")
  doRules         String   @default("")
  dontRules       String   @default("")
  bannedPhrases   String[] @default([])
  complianceRules String   @default("")
  exemplars       String   @default("")
  notes           String   @default("")
  createdById     String?
  createdAt       DateTime @default(now())

  createdBy User? @relation("VoiceProfileCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([version])
}

/// The seed insight a campaign is built around — the "vets cage dogs all day,
/// our suites have beds and TVs" observation. Scripts, ad copy, and creatives
/// hang off an idea. Status moves: DRAFT → IN_PRODUCTION → SHIPPED → ARCHIVED.
model MarketingIdea {
  id          String      @id @default(cuid())
  title       String
  insight     String      @default("")
  audience    String      @default("")
  serviceLine ServiceLine
  status      IdeaStatus  @default(DRAFT)
  tags        String[]    @default([])
  notes       String      @default("")
  createdById String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  createdBy User? @relation("MarketingIdeaCreator", fields: [createdById], references: [id], onDelete: SetNull)
  scripts   Script[]

  @@index([status])
  @@index([serviceLine])
  @@index([createdAt])
}

/// A short-form video script attached to an idea. Generated by the
/// Anthropic-backed generator (or hand-written) and contains many Hook
/// variants for the opener. `voiceProfileVersion` snapshots which voice
/// version was used so we can correlate quality changes back to specific
/// edits of the brand voice.
model Script {
  id                  String       @id @default(cuid())
  ideaId              String
  body                String       @default("")
  platform            Platform     @default(MULTI)
  status              ScriptStatus @default(DRAFT)
  voiceProfileVersion Int?
  /// Anthropic model id that produced this script (e.g. "claude-haiku-4-5").
  /// Null for hand-written scripts. Stored so we can correlate quality
  /// regressions to model swaps.
  model               String?
  /// Short slug pasted into the Meta ad name to auto-link insights back to
  /// this script (e.g. "pp-grm-suite-tour"). Whoever uploads the ad to
  /// Ads Manager is responsible for putting the slug in the name.
  metaAdSlug          String?      @unique
  notes               String       @default("")
  createdById         String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  idea      MarketingIdea  @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  createdBy User?          @relation("ScriptCreator", fields: [createdById], references: [id], onDelete: SetNull)
  hooks     Hook[]
  insights  MetaAdInsight[]

  @@index([ideaId])
  @@index([status])
}

/// A specific opener variant for a Script. Multiple hooks per script let us
/// split-test which one retains the viewer in the first 3 seconds.
model Hook {
  id                  String     @id @default(cuid())
  scriptId            String
  label               String     @default("")
  text                String
  order               Int        @default(0)
  status              HookStatus @default(DRAFT)
  voiceProfileVersion Int?
  /// Same as Script.model — denormalized onto Hook for easier per-hook
  /// quality analysis without joining back through Script.
  model               String?
  notes               String     @default("")
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  script Script @relation(fields: [scriptId], references: [id], onDelete: Cascade)

  @@index([scriptId])
}

/// One row per (Meta ad, day). Sourced from the Meta Marketing API
/// (`/{ad-account}/insights` with `time_increment=1`). Money is stored as
/// integer cents to avoid float drift; currency is taken from the ad account
/// at sync time and assumed consistent. The nightly cron re-syncs the last
/// 7 days because Meta backfills attribution for ~3.
///
/// `scriptId` is populated at sync time by matching `Script.metaAdSlug`
/// against `adName`. Null means we couldn't auto-link — surface those in the
/// UI so someone can rename the ad or set the slug.
model MetaAdInsight {
  id                 String   @id @default(cuid())
  adId               String
  adName             String
  campaignId         String?
  campaignName       String?
  adsetId            String?
  adsetName          String?
  date               DateTime @db.Date
  spendCents         Int      @default(0)
  impressions        Int      @default(0)
  reach              Int?
  frequency          Float?
  linkClicks         Int      @default(0)
  videoPlays3s       Int?
  videoThruplays     Int?
  purchases          Int      @default(0)
  purchaseValueCents Int      @default(0)
  scriptId           String?
  syncedAt           DateTime @default(now())

  script Script? @relation(fields: [scriptId], references: [id], onDelete: SetNull)

  @@unique([adId, date])
  @@index([date])
  @@index([scriptId])
}

/// One row per day-of-week the employee is available. Times are stored as
/// "HH:MM" 24-hour strings on 30-minute boundaries (e.g. "09:00", "17:30").
/// Days the employee is NOT available simply have no row — absence == off.
model EmployeeAvailability {
  id        String    @id @default(cuid())
  userId    String
  dayOfWeek DayOfWeek
  startTime String    // "HH:MM" 24-hour, 30-min increments
  endTime   String    // "HH:MM" 24-hour, 30-min increments
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dayOfWeek])
  @@index([userId])
}
