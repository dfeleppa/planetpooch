generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  MANAGER
  EMPLOYEE
  ADMIN // legacy — existing rows only, use SUPER_ADMIN for new admins
}

enum Company {
  MOBILE
  RESORT
}

enum AuditAction {
  COMPLETED
  UNCOMPLETED
}

enum RecurrenceInterval {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
  CUSTOM
}

enum MaintenanceTaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  OVERDUE
  SKIPPED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ============================================================
// Onboarding enums (Phase 2+)
// ============================================================

enum OnboardingTaskType {
  ESIGN_REQUEST       // Employee signs doc via Google eSignature (admin triggers)
  EMPLOYEE_CONFIRM    // Employee self-reports done (e.g., "Bring ID to meeting")
  ADMIN_FILE_UPLOAD   // Admin uploads a file to employee's Drive folder
  ADMIN_TASK          // Admin-only self-reported checkbox
}

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  passwordHash       String
  name               String
  role               Role      @default(EMPLOYEE)
  company            Company?
  mustChangePassword Boolean   @default(false)
  hireDate           DateTime?
  jobTitle           String?
  department         String?
  phone              String?
  managerId          String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  manager  User?  @relation("UserManager", fields: [managerId], references: [id])
  reports  User[] @relation("UserManager")

  completions LessonCompletion[]
  auditLogs   CompletionAuditLog[]
  notes       EmployeeNote[]

  // Maintenance relations
  maintenanceSchedulesCreated MaintenanceSchedule[] @relation("MaintenanceCreator")
  maintenanceTasksAssigned    MaintenanceTask[]     @relation("MaintenanceAssignee")
  maintenanceTasksCompleted   MaintenanceTask[]     @relation("MaintenanceCompleter")
  inventoryAdjustments        InventoryAdjustment[] @relation("InventoryAdjuster")

  // Task Manager relations
  projectsOwned    Project[]        @relation("ProjectOwner")
  projectMembers   ProjectMember[]
  tasksCreated     Task[]           @relation("TaskCreator")
  taskAssignments  TaskAssignee[]
  taskComments     TaskComment[]

  // Onboarding relations
  onboardingTemplatesCreated OnboardingTemplate[] @relation("TemplateCreator")
}

model Module {
  id          String   @id @default(cuid())
  title       String
  description String   @default("")
  order       Int
  icon        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subsections   Subsection[]
  prerequisites ModulePrerequisite[] @relation("DependentModule")
  dependents    ModulePrerequisite[] @relation("PrerequisiteModule")
}

model Subsection {
  id          String   @id @default(cuid())
  title       String
  description String   @default("")
  order       Int
  moduleId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  module  Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@index([moduleId])
}

model Lesson {
  id               String   @id @default(cuid())
  title            String
  content          Json     @default("{}")
  order            Int
  subsectionId     String
  estimatedMinutes Int?
  searchText       String   @default("")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  subsection  Subsection           @relation(fields: [subsectionId], references: [id], onDelete: Cascade)
  completions LessonCompletion[]
  auditLogs   CompletionAuditLog[]
  notes       EmployeeNote[]

  @@index([subsectionId])
}

model LessonCompletion {
  id          String   @id @default(cuid())
  userId      String
  lessonId    String
  completedAt DateTime @default(now())
  isCompleted Boolean  @default(true)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
}

model CompletionAuditLog {
  id                  String      @id @default(cuid())
  userId              String
  lessonId            String
  action              AuditAction
  timestamp           DateTime    @default(now())
  previousCompletedAt DateTime?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([lessonId])
  @@index([timestamp])
}

model ModulePrerequisite {
  id                   String @id @default(cuid())
  moduleId             String
  prerequisiteModuleId String

  module       Module @relation("DependentModule", fields: [moduleId], references: [id], onDelete: Cascade)
  prerequisite Module @relation("PrerequisiteModule", fields: [prerequisiteModuleId], references: [id], onDelete: Cascade)

  @@unique([moduleId, prerequisiteModuleId])
}

model EmployeeNote {
  id        String   @id @default(cuid())
  userId    String
  lessonId  String
  content   String   @default("")
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

// ============================================================
// Maintenance Models
// ============================================================

model MaintenanceSchedule {
  id                 String             @id @default(cuid())
  title              String
  description        String             @default("")
  recurrenceInterval RecurrenceInterval
  customIntervalDays Int?
  startDate          DateTime
  nextDueDate        DateTime
  isActive           Boolean            @default(true)
  createdById        String
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  createdBy    User                            @relation("MaintenanceCreator", fields: [createdById], references: [id])
  tasks        MaintenanceTask[]
  requirements MaintenanceInventoryRequirement[]

  @@index([nextDueDate])
  @@index([createdById])
}

model MaintenanceTask {
  id            String                @id @default(cuid())
  scheduleId    String?
  title         String
  description   String                @default("")
  status        MaintenanceTaskStatus @default(PENDING)
  dueDate       DateTime
  completedAt   DateTime?
  assignedToId  String?
  completedById String?
  notes         String                @default("")
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  schedule    MaintenanceSchedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  assignedTo  User?                @relation("MaintenanceAssignee", fields: [assignedToId], references: [id])
  completedBy User?                @relation("MaintenanceCompleter", fields: [completedById], references: [id])
  usages      InventoryUsage[]

  @@index([scheduleId])
  @@index([assignedToId])
  @@index([dueDate])
  @@index([status])
}

model InventoryCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("bg-gray-100 text-gray-800")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items InventoryItem[]
}

model InventoryItem {
  id               String   @id @default(cuid())
  name             String
  description      String   @default("")
  categoryId       String
  unit             String   @default("units")
  currentQuantity  Int      @default(0)
  minimumThreshold Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  category     InventoryCategory           @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  requirements MaintenanceInventoryRequirement[]
  usages       InventoryUsage[]
  adjustments  InventoryAdjustment[]

  @@index([categoryId])
}

model MaintenanceInventoryRequirement {
  id               String @id @default(cuid())
  scheduleId       String
  inventoryItemId  String
  quantityRequired Int

  schedule      MaintenanceSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem       @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@unique([scheduleId, inventoryItemId])
  @@index([inventoryItemId])
}

model InventoryUsage {
  id                String   @id @default(cuid())
  maintenanceTaskId String
  inventoryItemId   String
  quantityUsed      Int
  recordedAt        DateTime @default(now())

  maintenanceTask MaintenanceTask @relation(fields: [maintenanceTaskId], references: [id], onDelete: Cascade)
  inventoryItem   InventoryItem   @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@index([maintenanceTaskId])
  @@index([inventoryItemId])
}

model InventoryAdjustment {
  id              String   @id @default(cuid())
  inventoryItemId String
  quantityChange  Int
  reason          String   @default("")
  adjustedById    String
  createdAt       DateTime @default(now())

  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  adjustedBy    User          @relation("InventoryAdjuster", fields: [adjustedById], references: [id])

  @@index([inventoryItemId])
}

// ============================================================
// Task Manager Models
// ============================================================

model Project {
  id          String   @id @default(cuid())
  name        String
  description String   @default("")
  ownerId     String
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner       User            @relation("ProjectOwner", fields: [ownerId], references: [id])
  members     ProjectMember[]
  subProjects SubProject[]
  tasks       Task[]

  @@index([ownerId])
}

model SubProject {
  id          String   @id @default(cuid())
  name        String
  description String   @default("")
  projectId   String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@index([projectId])
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  role      String   @default("MEMBER")
  joinedAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
}

model Task {
  id           String       @id @default(cuid())
  title        String
  description  String       @default("")
  status       TaskStatus   @default(TODO)
  priority     TaskPriority @default(MEDIUM)
  order        Int          @default(0)
  dueDate      DateTime?
  projectId    String
  subProjectId String?
  parentTaskId String?
  createdById  String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  project    Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  subProject SubProject?  @relation(fields: [subProjectId], references: [id], onDelete: SetNull)
  parentTask Task?        @relation("TaskSubtasks", fields: [parentTaskId], references: [id], onDelete: Cascade)
  subtasks   Task[]       @relation("TaskSubtasks")
  createdBy  User         @relation("TaskCreator", fields: [createdById], references: [id])
  assignees  TaskAssignee[]
  comments   TaskComment[]

  @@index([projectId])
  @@index([subProjectId])
  @@index([parentTaskId])
  @@index([status])
  @@index([dueDate])
}

model TaskAssignee {
  id         String   @id @default(cuid())
  taskId     String
  userId     String
  assignedAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([userId])
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

// ============================================================
// Onboarding Models (Phase 2: templates only — no assignment yet)
// ============================================================

model OnboardingTemplate {
  id          String   @id @default(cuid())
  name        String
  description String   @default("")
  isActive    Boolean  @default(true)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User                     @relation("TemplateCreator", fields: [createdById], references: [id])
  tasks     OnboardingTemplateTask[]

  @@index([createdById])
}

model OnboardingTemplateTask {
  id          String             @id @default(cuid())
  templateId  String
  type        OnboardingTaskType
  title       String
  description String             @default("")
  required    Boolean            @default(true)
  order       Int
  // Type-specific fields (nullable because only some types use each)
  handbookFileName String?        // For ESIGN_REQUEST — label shown in admin UI
  externalUrl      String?        // For ADMIN_TASK — optional link (e.g., ADP)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  template OnboardingTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
}
